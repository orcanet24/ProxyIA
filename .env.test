# ── BASE DE DATOS ─────────────────────────────────────────────────────────────
# Si se deja comentado, se usa kairos.db en el mismo directorio que el ejecutable
# DATABASE_URL=sqlite:kairos.db?mode=rwc

# ── LOG DE AHORRO DE TOKENS ───────────────────────────────────────────────────
# Activa/desactiva el registro de ahorro de tokens en token_savings.log
# Valores: true | false (por defecto false)
TOKEN_SAVINGS_LOG=true

# ── LLM OPCIONAL PARA RESÚMENES CONCEPTUALES ──────────────────────────────────
# Si se configura, durante la indexación el LLM leerá cada archivo UNA SOLA VEZ
# y generará un resumen conceptual. Luego las búsquedas devuelven ese resumen.
# Sin esto, se usa el skeletonizer local (solo firmas de funciones, gratuito).
#
# API compatible con OpenAI (funciona con OpenAI, Claude API, Ollama, LocalAI, etc.)
# LLM_API_URL=https://api.openai.com/v1/chat/completions
# LLM_API_KEY=sk-tu-api-key
# LLM_MODEL=gpt-4o-mini
